// EDITORIAL PALETTE — warm, magazine-grade
// ═══════════════════════════════════════════════════════════════
const C = {
  bg:'#FAF8F5', card:'#FFFFFF', cardAlt:'#FFF8F0',
  border:'#E8E0D8', gridLine:'#EDE6DD', shadow:'0 1px 3px rgba(139,125,107,0.08), 0 4px 12px rgba(139,125,107,0.04)',
  text:'#2C2419', textSub:'#5C4F3D', muted:'#8B7D6B', faint:'#B0A494',
  deep:'#C85A3A', warm:'#D4714A', amber:'#E8985A', golden:'#F0B060', sand:'#F5D090', cream:'#FAE8C0',
  pos:'#27AE60', neg:'#C0392B', warn:'#E67E22',
  dataMuted:'#D5CBBD',
  pie:['#C85A3A','#D4714A','#E8985A','#F0B060','#8B7D6B','#5C4F3D','#B0A494','#D5CBBD'],
};
const AREA_COLORS = {Cucina:'#C85A3A',Sala:'#D4714A',Management:'#E8985A',Mgmt:'#E8985A',Amministrazione:'#F0B060',Amm:'#F0B060'};
const fontD = "Georgia, Charter, 'Palatino Linotype', serif";
const fontB = "-apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif";

const fmt = (v,d=0) => v==null?'\u2013':Number(v).toLocaleString('it-IT',{maximumFractionDigits:d,minimumFractionDigits:d});
const fmtK = v => v==null?'\u2013':Math.abs(v)>=1000?(v/1000).toLocaleString('it-IT',{maximumFractionDigits:1})+'K':fmt(v,0);
const fmtEur = v => '\u20AC'+fmtK(v);
const fmtP = v => v!=null&&!isNaN(v)?fmt(v,1)+'%':'\u2013';

const card = {background:C.card,borderRadius:10,padding:'24px',boxShadow:C.shadow,border:`1px solid ${C.border}`};

function KpiCard({label,value,sub,delta,good}) {
  return (
    <div style={card}>
      <div style={{fontSize:11,color:C.muted,textTransform:'uppercase',letterSpacing:0.8,marginBottom:6,fontFamily:fontB}}>{label}</div>
      <div style={{fontSize:28,fontWeight:700,color:C.text,marginBottom:6,fontFamily:fontD,letterSpacing:-0.5}}>{value}</div>
      <div style={{display:'flex',alignItems:'center',gap:8,flexWrap:'wrap'}}>
        {delta && <span style={{display:'inline-flex',alignItems:'center',gap:3,padding:'3px 10px',borderRadius:14,fontSize:11,fontWeight:600,
          background:good?'rgba(39,174,96,0.1)':'rgba(192,57,43,0.1)',color:good?C.pos:C.neg,fontFamily:fontB}}>
          {good?'\u25B2':'\u25BC'} {delta}
        </span>}
        {sub && <span style={{fontSize:12,color:C.faint,fontFamily:fontB}}>{sub}</span>}
      </div>
    </div>
  );
}

function Section({children,icon}) {
  return (
    <div style={{display:'flex',alignItems:'center',gap:10,margin:'40px 0 20px',paddingBottom:10,borderBottom:`2px solid ${C.border}`}}>
      {icon && <span style={{fontSize:22}}>{icon}</span>}
      <h2 style={{fontSize:20,fontWeight:700,color:C.text,margin:0,fontFamily:fontD,letterSpacing:-0.3}}>{children}</h2>
    </div>
  );
}

function ChartCard({title,insight,children,wide,height}) {
  return (
    <div style={{...card,gridColumn:wide?'1/-1':undefined}}>
      <h3 style={{fontSize:16,fontWeight:600,color:C.text,margin:0,fontFamily:fontB}}>{title}</h3>
      {insight && <p style={{fontSize:13,color:C.muted,margin:'4px 0 0',fontFamily:fontB}}>{insight}</p>}
      <div style={{height:height||300,marginTop:16}}>{children}</div>
    </div>
  );
}

function ProgressBar({label,current,target,unit,inverse}) {
  const pct = Math.min((current/target)*100,150);
  const good = inverse ? current<=target : current>=target;
  const pp = Math.min(pct,100);
  const barCol = good ? C.pos : pct>80 ? C.warn : C.neg;
  return (
    <div style={{...card,padding:'18px 22px'}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'baseline',marginBottom:10}}>
        <span style={{fontSize:13,fontWeight:600,color:C.text,fontFamily:fontB}}>{label}</span>
        <span style={{fontSize:13,color:C.muted,fontFamily:fontB}}>
          {unit==='\u20AC'?fmtEur(current):fmt(current,1)+'%'} / {unit==='\u20AC'?fmtEur(target):fmt(target,1)+'%'}
        </span>
      </div>
      <div style={{background:C.gridLine,borderRadius:6,height:6,overflow:'hidden'}}>
        <div style={{width:`${pp}%`,height:'100%',borderRadius:6,background:barCol,transition:'width 0.6s ease'}} />
      </div>
      <div style={{textAlign:'right',fontSize:11,color:C.muted,marginTop:6,fontFamily:fontB}}>
        {fmt(pct,0)}% {inverse?(good?'\u2713 in target':'\u2717 sopra target'):(good?'\u2713 raggiunto':`manca ${fmt(100-pct,0)}%`)}
      </div>
    </div>
  );
}

function CTip({active,payload,label,eurMode,pctMode}) {
  if (!active||!payload?.length) return null;
  return (
    <div style={{background:'#fff',border:`1px solid ${C.border}`,borderRadius:10,padding:'12px 16px',boxShadow:'0 4px 16px rgba(44,36,25,0.12)',fontFamily:fontB}}>
      <div style={{fontSize:13,fontWeight:600,color:C.text,marginBottom:6}}>{label}</div>
      {payload.map((p,i)=>(
        <div key={i} style={{fontSize:12,color:p.color||C.textSub,marginBottom:2}}>
          {p.name}: {eurMode?fmtEur(p.value):pctMode?fmt(p.value,1)+'%':fmt(p.value,2)}
        </div>
      ))}
    </div>
  );
}

