// ═══════════════════════════════════════════════════════════════
function Dashboard() {
  const [ratei,setRatei] = useState(false);
  const [extraBil,setExtraBil] = useState(true);

  if (!D) return <div style={{padding:60,textAlign:'center',color:C.muted,fontFamily:fontD,fontSize:18}}>Nessun dato caricato.</div>;

  const {meta,targets:TGT,pl26,pl25,ratei_deltas,hr,budget_pers,chiamate,area_costs,trend25,trend26,sale,canali,fidelizzazione,dist_nps,google_avg,anomalies} = D;
  const COMPLETE = meta.complete;
  const MESI = ["Gen","Feb","Mar","Apr","Mag","Giu","Lug","Ago","Set","Ott","Nov","Dic"];
  const MC = COMPLETE.length;
  const lastMonth = COMPLETE[MC-1];

  const data = useMemo(() => pl26.map(m => {
    if (!COMPLETE.includes(m.mese)) return {...m,_on:false};
    let d = {...m,_on:true};
    if (!extraBil) {
      d.ricavi -= d.ricavi_extra;
      d.ebitda -= (d.ricavi_extra+d.stipendio_amm+d.fuori_busta+d.bonus_vendita);
      d.personale -= (d.fuori_busta+d.bonus_vendita);
      d.costi_fissi -= d.stipendio_amm;
    }
    if (ratei && ratei_deltas[m.mese]!=null) {
      d.ebitda += ratei_deltas[m.mese];
      d.costi_fissi -= ratei_deltas[m.mese];
    }
    if (ratei || !extraBil) {
      if (d.ricavi>0) { d.pct_cogs=Math.abs(d.cogs)/d.ricavi*100; d.pct_personale=Math.abs(d.personale)/d.ricavi*100; d.pct_ebitda=d.ebitda/d.ricavi*100; }
    }
    if (d.ricavi>0 && d.cogs!==0) {
      const mc=(d.ricavi+d.cogs)/d.ricavi;
      if (mc>0) { d.break_even=(Math.abs(d.costi_fissi)+Math.abs(d.personale))/mc; d.surplus=d.ricavi-d.break_even; }
    }
    return d;
  }),[ratei,extraBil,pl26,COMPLETE,ratei_deltas]);

  const act = data.filter(d => d._on);

  const data25 = useMemo(() => pl25.map(m => {
    if (!extraBil) return {...m,ricavi:m.ricavi-m.ricavi_extra,ebitda:m.ebitda-(m.ricavi_extra+m.stipendio_amm+m.fuori_busta+m.bonus_vendita),personale:m.personale-(m.fuori_busta+m.bonus_vendita),costi_fissi:m.costi_fissi-m.stipendio_amm};
    return m;
  }),[pl25,extraBil]);

  const ytd = useMemo(() => {
    const r = act.reduce((a,m)=>({ric:a.ric+m.ricavi,ebi:a.ebi+m.ebitda,cog:a.cog+m.cogs,per:a.per+m.personale,bud:a.bud+m.budget_ricavi}),{ric:0,ebi:0,cog:0,per:0,bud:0});
    const ric25 = data25.slice(0,MC).reduce((a,m)=>a+m.ricavi,0);
    return {...r,ric25,ebiP:r.ric>0?r.ebi/r.ric*100:0,cogP:r.ric>0?Math.abs(r.cog)/r.ric*100:0,perP:r.ric>0?Math.abs(r.per)/r.ric*100:0};
  },[act,data25,MC]);

  const cd = useMemo(() => act.map(m => {
    const m25 = data25.find(x=>x.mese===m.mese)||{};
    return {
      mese:m.mese,ricavi:Math.round(m.ricavi),ric25:Math.round(m25.ricavi||0),
      budget:Math.round(m.budget_ricavi||0),ebitda:Math.round(m.ebitda),ebi25:Math.round(m25.ebitda||0),
      cogP:Math.round(m.pct_cogs*10)/10,cogP25:Math.round((m25.pct_cogs||0)*10)/10,
      perP:Math.round(m.pct_personale*10)/10,ebiP:Math.round(m.pct_ebitda*10)/10,
      pers:Math.round(Math.abs(m.personale)),persBud:Math.round(budget_pers+(chiamate[m.mese]||0)),
      vinoP:m.vino_pct,vinoP25:m25.vino_pct||0,
      beBase:m.break_even>0?Math.round(Math.min(m.ricavi,m.break_even)):0,
      beSurp:(m.surplus||0)>0?Math.round(m.surplus):0,
      beDef:(m.surplus||0)<0?Math.round(Math.abs(m.surplus)):0,
      surplus:Math.round(m.surplus||0),
      mc_pct:m.ricavi>0?(m.ricavi+m.cogs)/m.ricavi*100:0,
    };
  }),[act,data25,budget_pers,chiamate]);

  const vinoAvg = act.length>0?act.reduce((a,m)=>a+m.vino_pct,0)/act.length:0;

  const surveyKPI = useMemo(() => {
    const t26=trend26.filter(t=>t.n>0); const last=t26[t26.length-1]||{};
    const npsAvg=t26.length>0?t26.reduce((a,t)=>a+t.nps,0)/t26.length:0;
    const totalSurveys=t26.reduce((a,t)=>a+t.n,0);
    return {nps:last.nps||0,cucina:last.cucina||0,servizio:last.servizio||0,google:google_avg,
      npsAvg,totalSurveys,lastMese:last.mese||'\u2014',
      tornerebbe:t26.length>0?t26.reduce((a,t)=>a+(t.tornerebbe||0),0)/t26.length:0,
      prima_volta:t26.length>0?t26.reduce((a,t)=>a+(t.prima_volta||0),0)/t26.length:0,
      ritmo_giusto:t26.length>0?t26.reduce((a,t)=>a+(t.ritmo_giusto||0),0)/t26.length:0,
      lento:t26.length>0?t26.reduce((a,t)=>a+(t.lento||0),0)/t26.length:0,
      lastGoogle:last.google||0};
  },[trend26,google_avg]);

  const revenueData = MESI.map((m,i)=>({mese:m,'2025':data25[i]?.ricavi||0,'Budget':pl26[i]?.budget_ricavi||0,'2026':i<MC?(cd[i]?.ricavi):null}));
  const surveyTrend = useMemo(()=>trend26.filter(t=>t.n>0).map(t=>{const t25=trend25.find(x=>x.mese===t.mese)||{};return {mese:t.mese,nps:t.nps,nps25:t25.nps||null,cucina:t.cucina,servizio:t.servizio,n:t.n};}),[trend26,trend25]);
  const marginsData = cd.map(d=>({mese:d.mese,'COGS %':d.cogP,'COGS 25':d.cogP25,'Personale %':d.perP,'EBITDA %':d.ebiP}));
  const vinoData = MESI.map((m,i)=>({mese:m,'2025':data25[i]?.vino_pct||0,'2026':i<MC?(act.find(a=>a.mese===m)?.vino_pct||null):null,target:TGT.vino_pct}));
  const googleData = MESI.map((m,i)=>{const t26=trend26.find(t=>t.mese===m);const t25=trend25.find(t=>t.mese===m);return {mese:m,'2026':t26&&t26.n>0?t26.google:null,'2025':t25?t25.google:null,target:TGT.google_reviews};});
  const areaPieData = Object.entries(area_costs).map(([name,value])=>({name,value:Math.round(Math.abs(value))}));
  const persData = cd.map(d=>({mese:d.mese,'Effettivo':d.pers,'Budget':d.persBud}));
  const npsColors = {10:C.pos,9:C.golden,8:C.warn,7:C.neg};
  const npsDistData = [...dist_nps].filter(d=>d.score>=1).sort((a,b)=>b.score-a.score).map(d=>({...d,fill:npsColors[d.score]||C.neg}));
  const sortedCanali = [...canali].sort((a,b)=>b.n-a.n);

  const ricDelta = ytd.bud>0?((ytd.ric/ytd.bud-1)*100):0;
  const ricVs25 = ytd.ric25>0?((ytd.ric/ytd.ric25-1)*100):0;

  return (
    <div style={{background:C.bg,minHeight:'100vh',fontFamily:fontB,color:C.text}}>
      <div style={{maxWidth:1400,margin:'0 auto',padding:'20px 24px'}}>

        {/* HEADER */}
        <div style={{background:'linear-gradient(135deg, #2C2419 0%, #3D3124 50%, #4A3C2E 100%)',color:'#FAF8F5',borderRadius:14,padding:'28px 36px',display:'flex',justifyContent:'space-between',alignItems:'center',flexWrap:'wrap',gap:16,marginBottom:24,boxShadow:'0 4px 20px rgba(44,36,25,0.25)'}}>
          <div>
            <h1 style={{fontSize:28,fontWeight:700,margin:0,fontFamily:fontD,letterSpacing:-0.5}}>{`I B\u00F9gian\u00E8n`}</h1>
            <p style={{fontSize:14,opacity:0.5,margin:'6px 0 0',fontFamily:fontB,letterSpacing:3,textTransform:'uppercase'}}>{`Cruscotto ${lastMonth?'Gen\u2013'+lastMonth:''} 2026`}</p>
          </div>
          <div style={{display:'flex',gap:20,alignItems:'center'}}>
            <label style={{display:'flex',alignItems:'center',gap:8,fontSize:13,cursor:'pointer',opacity:0.85}}>
              <input type="checkbox" checked={ratei} onChange={e=>setRatei(e.target.checked)} style={{accentColor:C.amber,width:16,height:16}} /> Ratei CF
            </label>
            <label style={{display:'flex',alignItems:'center',gap:8,fontSize:13,cursor:'pointer',opacity:0.85}}>
              <input type="checkbox" checked={extraBil} onChange={e=>setExtraBil(e.target.checked)} style={{accentColor:C.amber,width:16,height:16}} /> Extra-bilancio
            </label>
          </div>
        </div>

        {/* KPI CARDS */}
        <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit, minmax(220px, 1fr))',gap:16,marginBottom:24}}>
          <KpiCard label="Ricavi YTD" value={fmtEur(ytd.ric)} good={ytd.ric>=ytd.bud} delta={`${ricDelta>=0?'+':''}${fmt(ricDelta,1)}% vs budget`} sub={`${ricVs25>=0?'+':''}${fmt(ricVs25,1)}% vs 2025`} />
          <KpiCard label="EBITDA Margin" value={fmtP(ytd.ebiP)} good={ytd.ebiP>=TGT.ebitda_pct} delta={`target ${TGT.ebitda_pct}%`} sub={fmtEur(ytd.ebi)+' totale'} />
          <KpiCard label="Vino % (media)" value={fmtP(vinoAvg)} good={vinoAvg>=TGT.vino_pct} delta={`target \u2265${TGT.vino_pct}%`} />
          <KpiCard label="NPS Medio" value={fmt(surveyKPI.npsAvg,2)} good={surveyKPI.npsAvg>=9.0} delta="benchmark 9.0" sub={`${fmt(surveyKPI.totalSurveys,0)} sondaggi YTD`} />
        </div>

        {/* TARGETS */}
        <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit, minmax(280px, 1fr))',gap:16,marginBottom:24}}>
          <ProgressBar label="Fatturato 2026" current={ytd.ric} target={TGT.fatturato} unit={'\u20AC'} />
          <ProgressBar label="EBITDA %" current={ytd.ebiP} target={TGT.ebitda_pct} unit="%" />
          <ProgressBar label="COGS %" current={ytd.cogP} target={TGT.cogs_pct} unit="%" inverse />
          <ProgressBar label="Vino %" current={vinoAvg} target={TGT.vino_pct} unit="%" />
        </div>

        {/* ═══ FINANCIAL ═══ */}
        <Section icon={'\uD83D\uDCC8'}>Performance Finanziaria</Section>
        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:16,marginBottom:16}}>
          <ChartCard title={`Ricavi: ${ricDelta>=0?'+':''}${fmt(ricDelta,1)}% vs budget, ${ricVs25>=0?'+':''}${fmt(ricVs25,0)}% vs 2025`} insight="Barre colorate se sopra/sotto budget. Linee tratteggiate = 2025 e budget.">
            <ResponsiveContainer width="100%" height="100%">
              <ComposedChart data={revenueData} margin={{top:10,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} tickFormatter={v=>fmtK(v)} axisLine={false} />
                <Tooltip content={<CTip eurMode />} />
                <Legend iconType="circle" wrapperStyle={{fontSize:11,color:C.muted}} />
                <Line type="monotone" dataKey="2025" stroke={C.dataMuted} strokeWidth={2} dot={false} strokeDasharray="4 4" />
                <Line type="monotone" dataKey="Budget" stroke={C.muted} strokeWidth={2} dot={false} strokeDasharray="6 3" />
                <Bar dataKey="2026" radius={[6,6,0,0]} barSize={36}>
                  {revenueData.map((d,i)=><Cell key={i} fill={d['2026']!=null?(d['2026']>=d['Budget']?C.pos:C.deep):'transparent'} />)}
                  <LabelList dataKey="2026" position="top" formatter={v=>v?fmtK(v):''} style={{fontSize:10,fill:C.text,fontWeight:600}} />
                </Bar>
              </ComposedChart>
            </ResponsiveContainer>
          </ChartCard>

          <ChartCard title={`Margini: Personale ${fmt(ytd.perP,1)}%, EBITDA ${fmt(ytd.ebiP,1)}%`} insight={`Target EBITDA \u2265${TGT.ebitda_pct}%. Verde = sopra target.`}>
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={marginsData} margin={{top:10,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} tickFormatter={v=>v+'%'} domain={[0,60]} axisLine={false} />
                <Tooltip content={<CTip pctMode />} />
                <Legend iconType="circle" wrapperStyle={{fontSize:11}} />
                <ReferenceLine y={TGT.ebitda_pct} stroke={C.pos} strokeDasharray="4 4" label={{value:`EBITDA \u2265${TGT.ebitda_pct}%`,position:'right',fontSize:10,fill:C.pos}} />
                <Bar dataKey="Personale %" fill={C.dataMuted} radius={[6,6,0,0]} barSize={32} fillOpacity={0.8}>
                  <LabelList dataKey="Personale %" position="top" formatter={v=>fmt(v,0)+'%'} style={{fontSize:10,fill:C.muted}} />
                </Bar>
                <Bar dataKey="EBITDA %" radius={[6,6,0,0]} barSize={32}>
                  {marginsData.map((d,i)=><Cell key={i} fill={d['EBITDA %']>=TGT.ebitda_pct?C.pos:C.warm} fillOpacity={0.85} />)}
                  <LabelList dataKey="EBITDA %" position="top" formatter={v=>fmt(v,0)+'%'} style={{fontSize:10,fontWeight:600}} />
                </Bar>
              </BarChart>
            </ResponsiveContainer>
          </ChartCard>
        </div>

        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:16,marginBottom:16}}>
          <ChartCard title={`COGS a ${fmt(ytd.cogP,1)}% \u2014 ${ytd.cogP<=TGT.cogs_pct?'in target':'sopra target '+TGT.cogs_pct+'%'}`} insight="Zona verde = sotto target. Linea 2025 per confronto storico.">
            <ResponsiveContainer width="100%" height="100%">
              <ComposedChart data={marginsData} margin={{top:20,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} tickFormatter={v=>v+'%'} domain={[0,50]} axisLine={false} />
                <Tooltip content={<CTip pctMode />} />
                <Legend iconType="circle" wrapperStyle={{fontSize:11}} />
                <ReferenceArea y1={0} y2={TGT.cogs_pct} fill={C.pos} fillOpacity={0.04} />
                <ReferenceArea y1={TGT.cogs_pct} y2={50} fill={C.neg} fillOpacity={0.04} />
                <ReferenceLine y={TGT.cogs_pct} stroke={C.neg} strokeWidth={2} strokeDasharray="6 3" label={{value:`\u2264${TGT.cogs_pct}%`,position:'insideTopRight',fontSize:11,fill:C.neg,fontWeight:600}} />
                <Bar dataKey="COGS %" radius={[6,6,0,0]} barSize={40}>
                  {marginsData.map((d,i)=><Cell key={i} fill={d['COGS %']<=TGT.cogs_pct?C.pos:C.deep} fillOpacity={0.85} />)}
                  <LabelList dataKey="COGS %" position="top" formatter={v=>fmt(v,1)+'%'} style={{fontSize:11,fontWeight:600}} />
                </Bar>
                <Line type="monotone" dataKey="COGS 25" stroke={C.dataMuted} strokeWidth={2} dot={{r:4,fill:C.dataMuted}} name="COGS 2025" />
              </ComposedChart>
            </ResponsiveContainer>
          </ChartCard>

          <ChartCard title={`EBITDA: ${ytd.ebi>=0?'+':''}${fmtEur(ytd.ebi)} YTD`} insight="Verde = positivo, terracotta = negativo. Grigio = 2025.">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={cd} margin={{top:20,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} tickFormatter={v=>fmtK(v)} axisLine={false} />
                <Tooltip content={<CTip eurMode />} />
                <Legend iconType="circle" wrapperStyle={{fontSize:11}} />
                <ReferenceLine y={0} stroke={C.border} />
                <Bar dataKey="ebi25" name="2025" fill={C.dataMuted} radius={[6,6,0,0]} barSize={28} fillOpacity={0.6} />
                <Bar dataKey="ebitda" name="2026" radius={[6,6,0,0]} barSize={28}>
                  {cd.map((d,i)=><Cell key={i} fill={d.ebitda>=0?C.pos:C.deep} />)}
                  <LabelList dataKey="ebitda" position="top" formatter={v=>v!=null?fmtEur(v):''} style={{fontSize:10,fontWeight:600}} />
                </Bar>
              </BarChart>
            </ResponsiveContainer>
          </ChartCard>
        </div>

        {/* Break-Even + Vino */}
        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:16,marginBottom:16}}>
          <ChartCard title="Break-Even: dove siamo rispetto al pareggio" insight="Grigio = copertura BE. Verde = surplus, terracotta = deficit.">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={cd} margin={{top:20,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} tickFormatter={v=>fmtK(v)} domain={[0,'auto']} axisLine={false} />
                <Tooltip content={({active,payload,label}) => {
                  if (!active||!payload?.length) return null;
                  const d = cd.find(x=>x.mese===label); if (!d) return null;
                  return (<div style={{background:'#fff',border:`1px solid ${C.border}`,borderRadius:10,padding:'12px 16px',boxShadow:'0 4px 16px rgba(44,36,25,0.12)',fontFamily:fontB}}>
                    <div style={{fontSize:13,fontWeight:600,marginBottom:6}}>{label}</div>
                    <div style={{fontSize:12,color:C.amber}}>Ricavi: {fmtEur(d.ricavi)}</div>
                    <div style={{fontSize:12,color:C.muted}}>Break-even: {fmtEur(d.beBase)}</div>
                    <div style={{fontSize:12,color:C.warn}}>MC%: {fmt(d.mc_pct,1)}%</div>
                    <div style={{fontSize:12,fontWeight:700,color:d.surplus>=0?C.pos:C.neg,marginTop:4}}>
                      {d.surplus>=0?'+ ':'\u2013 '}{fmtEur(Math.abs(d.surplus))} {d.surplus>=0?'surplus':'deficit'}
                    </div>
                  </div>);
                }} />
                <Bar dataKey="beBase" name="Copertura BE" stackId="be" fill={C.dataMuted} barSize={48} />
                <Bar dataKey="beSurp" name="Surplus" stackId="be" fill={C.pos} radius={[6,6,0,0]} barSize={48}>
                  <LabelList content={({x,y,width,index}) => {
                    const d=cd[index]; if (!d||d.surplus===0) return null;
                    return <text x={x+width/2} y={y-10} textAnchor="middle" fontSize={12} fontWeight={700} fill={d.surplus>=0?C.pos:C.neg}>{d.surplus>=0?'+':'\u2013'}{fmtEur(Math.abs(d.surplus))}</text>;
                  }} />
                </Bar>
                <Bar dataKey="beDef" name="Deficit" stackId="be" fill={C.deep} radius={[6,6,0,0]} barSize={48} />
              </BarChart>
            </ResponsiveContainer>
          </ChartCard>

          <ChartCard title={`Vino a ${fmt(vinoAvg,1)}% \u2014 ${vinoAvg>=TGT.vino_pct?'sopra':'sotto'} target ${TGT.vino_pct}%`} insight="Barre 2026, linea 2025. Target tratteggiato verde.">
            <ResponsiveContainer width="100%" height="100%">
              <ComposedChart data={vinoData} margin={{top:10,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} tickFormatter={v=>v+'%'} domain={[0,30]} axisLine={false} />
                <Tooltip content={<CTip pctMode />} />
                <Legend iconType="circle" wrapperStyle={{fontSize:11}} />
                <ReferenceLine y={TGT.vino_pct} stroke={C.pos} strokeDasharray="4 4" label={{value:`${TGT.vino_pct}%`,position:'right',fontSize:10,fill:C.pos}} />
                <Bar dataKey="2026" radius={[6,6,0,0]} barSize={32}>
                  {vinoData.map((d,i)=><Cell key={i} fill={d['2026']!=null?(d['2026']>=TGT.vino_pct?C.pos:C.warm):'transparent'} />)}
                  <LabelList dataKey="2026" position="top" formatter={v=>v?fmt(v,1)+'%':''} style={{fontSize:10,fontWeight:600}} />
                </Bar>
                <Line type="monotone" dataKey="2025" stroke={C.dataMuted} strokeWidth={2.5} dot={{r:4,fill:C.dataMuted,stroke:'#fff',strokeWidth:2}} />
              </ComposedChart>
            </ResponsiveContainer>
          </ChartCard>
        </div>

        {/* ═══ PEOPLE ═══ */}
        <Section icon={'\uD83D\uDC65'}>Costo del Personale</Section>
        <div style={{display:'grid',gridTemplateColumns:'2fr 1fr',gap:16,marginBottom:16}}>
          <ChartCard title={`Personale: ${cd.every(d=>d.pers<=d.persBud)?'in budget':'alcuni mesi sopra budget'}`} insight="Terracotta = sopra budget. Grigio = budget di riferimento.">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={persData} margin={{top:20,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} tickFormatter={v=>fmtK(v)} axisLine={false} />
                <Tooltip content={<CTip eurMode />} />
                <Legend iconType="circle" wrapperStyle={{fontSize:11}} />
                <Bar dataKey="Effettivo" radius={[6,6,0,0]} barSize={36}>
                  {persData.map((d,i)=><Cell key={i} fill={d['Effettivo']<=d['Budget']?C.pos:C.deep} />)}
                  <LabelList dataKey="Effettivo" position="top" formatter={v=>fmtEur(v)} style={{fontSize:10,fontWeight:600}} />
                </Bar>
                <Bar dataKey="Budget" fill={C.dataMuted} radius={[6,6,0,0]} barSize={36} fillOpacity={0.4}>
                  <LabelList dataKey="Budget" position="top" formatter={v=>fmtEur(v)} style={{fontSize:10,fill:C.faint}} />
                </Bar>
              </BarChart>
            </ResponsiveContainer>
          </ChartCard>

          <ChartCard title="Distribuzione per Area" insight="Proporzione costi personale per area.">
            <ResponsiveContainer width="100%" height="100%">
              <PieChart>
                <Pie data={areaPieData} cx="50%" cy="50%" innerRadius={60} outerRadius={95} paddingAngle={3} dataKey="value"
                  label={({name,percent})=>`${name} ${(percent*100).toFixed(0)}%`} labelLine={{stroke:C.muted,strokeWidth:1}}>
                  {areaPieData.map((d,i)=><Cell key={i} fill={AREA_COLORS[d.name]||C.muted} />)}
                </Pie>
                <Tooltip formatter={v=>fmtEur(v)} />
              </PieChart>
            </ResponsiveContainer>
          </ChartCard>
        </div>

        {/* ═══ QUALITY ═══ */}
        <Section icon={'\u2B50'}>{`Qualit\u00E0 e Soddisfazione`}</Section>
        <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit, minmax(170px, 1fr))',gap:16,marginBottom:16}}>
          <KpiCard label={`NPS (${surveyKPI.lastMese})`} value={fmt(surveyKPI.nps,2)} good={surveyKPI.nps>=9.0} delta={'\u2265 9.0'} sub={`Media YTD: ${fmt(surveyKPI.npsAvg,2)}`} />
          <KpiCard label="Cucina" value={`${fmt(surveyKPI.cucina,2)}/5`} good={surveyKPI.cucina>=4.7} delta={'\u2265 4.7'} />
          <KpiCard label="Servizio" value={`${fmt(surveyKPI.servizio,2)}/5`} good={surveyKPI.servizio>=4.7} delta={'\u2265 4.7'} />
          <KpiCard label="Google Reviews" value={fmt(surveyKPI.lastGoogle,2)} good={surveyKPI.lastGoogle>=TGT.google_reviews} delta={`tgt \u2265${TGT.google_reviews}`} sub={`Media: ${fmt(surveyKPI.google,2)}`} />
          <KpiCard label="Sondaggi YTD" value={fmt(surveyKPI.totalSurveys,0)} sub={`${surveyTrend.length} mesi con dati`} />
        </div>

        <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit, minmax(170px, 1fr))',gap:16,marginBottom:20}}>
          <div style={{...card,background:C.cardAlt}}>
            <div style={{fontSize:11,color:C.muted,textTransform:'uppercase',letterSpacing:0.8,marginBottom:10,fontFamily:fontB}}>Metriche Operative (media YTD)</div>
            <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10,fontSize:13}}>
              <div>Tornerebbe: <strong style={{color:surveyKPI.tornerebbe>=95?C.pos:C.warn}}>{fmt(surveyKPI.tornerebbe,0)}%</strong></div>
              <div>Ritmo OK: <strong style={{color:surveyKPI.ritmo_giusto>=90?C.pos:C.warn}}>{fmt(surveyKPI.ritmo_giusto,0)}%</strong></div>
              <div>Prima Volta: <strong>{fmt(surveyKPI.prima_volta,0)}%</strong></div>
              <div>Serv. Lento: <strong style={{color:surveyKPI.lento<=5?C.pos:C.neg}}>{fmt(surveyKPI.lento,1)}%</strong></div>
            </div>
          </div>
        </div>

        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:16,marginBottom:16}}>
          <ChartCard title={`NPS & Voti: trend qualit\u00E0 nel tempo`} insight="NPS asse sinistro (7\u201310), voti cucina/servizio asse destro (3\u20135)." height={320}>
            <ResponsiveContainer width="100%" height="100%">
              <ComposedChart data={surveyTrend} margin={{top:5,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} />
                <YAxis yAxisId="nps" domain={[7,10]} tick={{fontSize:10,fill:C.muted}} axisLine={false} />
                <YAxis yAxisId="voti" orientation="right" domain={[3,5]} tick={{fontSize:10,fill:C.muted}} axisLine={false} />
                <Tooltip content={<CTip />} />
                <Legend wrapperStyle={{fontSize:11}} />
                <Line yAxisId="nps" dataKey="nps" name="NPS 2026" stroke={C.deep} strokeWidth={2.5} dot={{r:5,fill:C.deep,stroke:'#fff',strokeWidth:2}} />
                <Line yAxisId="nps" dataKey="nps25" name="NPS 2025" stroke={C.dataMuted} strokeDasharray="5 5" dot={false} />
                <Line yAxisId="voti" dataKey="cucina" name="Cucina" stroke={C.amber} strokeWidth={2} dot={{r:4,fill:C.amber,stroke:'#fff',strokeWidth:2}} />
                <Line yAxisId="voti" dataKey="servizio" name="Servizio" stroke={C.golden} strokeWidth={2} dot={{r:4,fill:C.golden,stroke:'#fff',strokeWidth:2}} />
              </ComposedChart>
            </ResponsiveContainer>
          </ChartCard>

          <ChartCard title={`Google Reviews: ${surveyKPI.lastGoogle>=TGT.google_reviews?'sopra':'sotto'} target ${TGT.google_reviews}`} insight="Barre 2026 vs linea 2025. Obiettivo tratteggiato verde." height={320}>
            <ResponsiveContainer width="100%" height="100%">
              <ComposedChart data={googleData} margin={{top:10,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="mese" tick={{fontSize:11,fill:C.muted}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} domain={[3.5,5.2]} tickFormatter={v=>fmt(v,1)} axisLine={false} />
                <Tooltip content={<CTip />} />
                <Legend iconType="circle" wrapperStyle={{fontSize:11}} />
                <ReferenceLine y={TGT.google_reviews} stroke={C.pos} strokeDasharray="4 4" label={{value:`${TGT.google_reviews}`,position:'right',fontSize:10,fill:C.pos}} />
                <Bar dataKey="2026" radius={[6,6,0,0]} barSize={32}>
                  {googleData.map((d,i)=><Cell key={i} fill={d['2026']!=null?(d['2026']>=TGT.google_reviews?C.pos:C.warm):'transparent'} />)}
                  <LabelList dataKey="2026" position="top" formatter={v=>v?fmt(v,2):''} style={{fontSize:10,fontWeight:600}} />
                </Bar>
                <Line type="monotone" dataKey="2025" stroke={C.dataMuted} strokeWidth={2.5} dot={{r:4,fill:C.dataMuted,stroke:'#fff',strokeWidth:2}} />
              </ComposedChart>
            </ResponsiveContainer>
          </ChartCard>
        </div>

        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr 1fr',gap:16,marginBottom:16}}>
          <ChartCard title="Come ci trovano" insight="Canali acquisizione, per frequenza." height={280}>
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={sortedCanali} layout="vertical" margin={{top:5,right:40,bottom:5,left:80}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} horizontal={false} />
                <XAxis type="number" tick={{fontSize:11,fill:C.muted}} axisLine={false} />
                <YAxis type="category" dataKey="canale" tick={{fontSize:11,fill:C.textSub}} width={75} axisLine={false} />
                <Tooltip />
                <Bar dataKey="n" name="Risposte" radius={[0,6,6,0]} barSize={18}>
                  {sortedCanali.map((d,i)=><Cell key={i} fill={C.pie[i%C.pie.length]} fillOpacity={0.8} />)}
                  <LabelList dataKey="n" position="right" style={{fontSize:10,fill:C.text,fontWeight:600}} />
                </Bar>
              </BarChart>
            </ResponsiveContainer>
          </ChartCard>

          <ChartCard title="Clienti di ritorno vs nuovi" insight="Distribuzione fidelizzazione." height={280}>
            <ResponsiveContainer width="100%" height="100%">
              <PieChart>
                <Pie data={fidelizzazione} cx="50%" cy="50%" innerRadius={60} outerRadius={90} paddingAngle={3} dataKey="n" nameKey="tipo"
                  label={({tipo,percent})=>`${tipo} ${(percent*100).toFixed(0)}%`} labelLine={{stroke:C.muted}}>
                  {fidelizzazione.map((d,i)=><Cell key={i} fill={C.pie[i]} />)}
                </Pie>
                <Tooltip />
              </PieChart>
            </ResponsiveContainer>
          </ChartCard>

          <ChartCard title="Distribuzione NPS" insight="Sopra 9 = promoter." height={280}>
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={npsDistData} margin={{top:20,right:20,bottom:5,left:10}}>
                <CartesianGrid strokeDasharray="3 3" stroke={C.gridLine} />
                <XAxis dataKey="score" tick={{fontSize:12,fill:C.textSub}} axisLine={{stroke:C.dataMuted}} />
                <YAxis tick={{fontSize:11,fill:C.muted}} axisLine={false} />
                <Tooltip />
                <Bar dataKey="n" name="Risposte" radius={[6,6,0,0]}>
                  {npsDistData.map((d,i)=><Cell key={i} fill={d.fill} fillOpacity={0.85} />)}
                  <LabelList dataKey="n" position="top" style={{fontSize:10,fontWeight:600,fill:C.text}} />
                </Bar>
              </BarChart>
            </ResponsiveContainer>
          </ChartCard>
        </div>

        {/* ── Performance per Sala ── */}
        {sale.length>0 && (
          <div style={{...card,marginBottom:16}}>
            <h3 style={{fontSize:16,fontWeight:600,margin:'0 0 4px',fontFamily:fontB}}>Performance per Sala (YTD 2026)</h3>
            <p style={{fontSize:13,color:C.muted,margin:'0 0 16px',fontFamily:fontB}}>Dati aggregati da inizio anno. NPS, Cucina e Servizio sono medie ponderate.</p>
            <table style={{width:'100%',borderCollapse:'collapse',fontSize:13,fontFamily:fontB}}>
              <thead><tr style={{borderBottom:`2px solid ${C.border}`}}>
                {['Sala','Coperti','Risposte','NPS','Cucina','Servizio'].map(h=>
                  <th key={h} style={{textAlign:h==='Sala'?'left':'right',padding:'10px 12px',color:C.muted,fontWeight:600,fontSize:11,textTransform:'uppercase',letterSpacing:0.5}}>{h}</th>
                )}
              </tr></thead>
              <tbody>
                {sale.map((s,i)=>(
                  <tr key={i} style={{borderBottom:`1px solid ${C.gridLine}`}}>
                    <td style={{padding:'10px 12px',fontWeight:600}}>{s.sala}</td>
                    <td style={{padding:'10px 12px',textAlign:'right'}}>{s.coperti}</td>
                    <td style={{padding:'10px 12px',textAlign:'right',color:C.muted}}>{s.risposte||'\u2013'}</td>
                    <td style={{padding:'10px 12px',textAlign:'right'}}><strong style={{color:s.nps>=9.3?C.pos:s.nps>=9.0?C.amber:C.neg}}>{fmt(s.nps,2)}</strong></td>
                    <td style={{padding:'10px 12px',textAlign:'right'}}><strong style={{color:(s.cucina||0)>=4.8?C.pos:(s.cucina||0)>=4.5?C.amber:C.warn}}>{fmt(s.cucina,2)}</strong></td>
                    <td style={{padding:'10px 12px',textAlign:'right'}}><strong style={{color:(s.servizio||0)>=4.8?C.pos:(s.servizio||0)>=4.5?C.amber:C.warn}}>{fmt(s.servizio,2)}</strong></td>
                  </tr>
                ))}
                <tr style={{borderTop:`2px solid ${C.text}`,fontWeight:700}}>
                  <td style={{padding:'10px 12px'}}>Totale</td>
                  <td style={{padding:'10px 12px',textAlign:'right'}}>{sale.reduce((a,s)=>a+s.coperti,0)}</td>
                  <td style={{padding:'10px 12px',textAlign:'right',color:C.muted}}>{sale.reduce((a,s)=>a+(s.risposte||0),0)}</td>
                  <td colSpan={3} />
                </tr>
              </tbody>
            </table>
          </div>
        )}

        {/* Footer */}
        <div style={{textAlign:'center',padding:'24px 0',color:C.faint,fontSize:11,borderTop:`1px solid ${C.border}`,marginTop:24,fontFamily:fontB}}>
          <p style={{margin:0}}>{`I B\u00F9gian\u00E8n \u2014 Gen\u2013${lastMonth} 2026 \u00B7 ${meta.generated?.split('T')[0]||''}`}</p>
          <p style={{margin:'4px 0 0',color:C.dataMuted}}>{`Toggle ratei: media mensile 2025 \u00B7 Toggle extra-bilancio: RNB + stip. amm. + fuori busta + bonus vendita`}</p>
        </div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(Dashboard));

</script>
</body>
</html>
